title: $:/plugins/nikorion/math/test
type: text/vnd.tiddlywiki

\define stateTidd() $:/state/plugins/nikorion/math/test

\function locale()   [<stateTidd>get[locale]else[en-US]]
\function notation() [<stateTidd>get[notation]else[auto]]
\function show()     [<stateTidd>get[show]else[result]]
\function mode()     [<stateTidd>get[mode]else[inline]]
\function silence()  [<stateTidd>get[silence]else[no]]
\function calcPrec()  [<stateTidd>get[calcPrec]else[float]]
\function output()    [<stateTidd>get[output]else[katex]]
\function precision() [<stateTidd>get[precision]]
\function scope()     [<stateTidd>get[scope]]
\function expr()      [<stateTidd>get[expression]]

<style>
.locale-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.locale-row .tc-radio {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
}
</style>

<table>
<tr>
<th>Attributes</th>
</tr>
<tr>
<td class="locale-row">
`output`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="output" value="katex" default="katex">&nbsp;katex&nbsp;(default)</$radio>
<$radio field="output" value="text">&nbsp;text</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`locale`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="locale" value="en-US" default="en-US">&nbsp;en-US&nbsp;(default)</$radio>
<$radio field="locale" value="fr-FR">&nbsp;fr-FR</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`show`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="show" value="result" default="result">&nbsp;result&nbsp;(default)</$radio>
<$radio field="show" value="formula">&nbsp;formula</$radio>
<$radio field="show" value="full">&nbsp;full</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`notation`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="notation" value="auto" default="auto">&nbsp;auto&nbsp;(default)</$radio>
<$radio field="notation" value="fixed">&nbsp;fixed</$radio>
<$radio field="notation" value="scientific">&nbsp;scientific</$radio>
<$radio field="notation" value="engineering">&nbsp;engineering</$radio>
<$radio field="notation" value="bin">&nbsp;bin</$radio>
<$radio field="notation" value="oct">&nbsp;oct</$radio>
<$radio field="notation" value="hex">&nbsp;hex</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`precision`
<$tiddler tiddler=<<stateTidd>>>
<$edit-text field="precision" placeholder="default (6)" size=8/>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`mode`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="mode" value="inline" default="inline">&nbsp;inline&nbsp;(default)</$radio>
<$radio field="mode" value="block">&nbsp;block</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`calcPrec`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="calcPrec" value="float" default="float">&nbsp;float&nbsp;(default)</$radio>
<$radio field="calcPrec" value="64">&nbsp;64</$radio>
<$radio field="calcPrec" value="128">&nbsp;128</$radio>
<$radio field="calcPrec" value="256">&nbsp;256</$radio>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`scope`
<$tiddler tiddler=<<stateTidd>>>
<$edit-text field="scope" placeholder="{a: 2, b: 5}" size=24/>
</$tiddler></td>
</tr>
<tr>
<td class="locale-row">
`silence`
<$tiddler tiddler=<<stateTidd>>>
<$radio field="silence" value="no" default="no">&nbsp;no&nbsp;(default)</$radio>
<$radio field="silence" value="yes">&nbsp;yes</$radio>
</$tiddler></td>
</tr>
</table>

<$edit-text tiddler=<<stateTidd>> field="expression" placeholder="Expression" size=36/>
<$button tooltip="restore default" class="tc-btn-invisible" actions="""<$action-deletetiddler $tiddler=<<stateTidd>>/>""">{{$:/core/images/refresh-button}}</$button>
<$list filter="[<stateTidd>has[expression]]">
<$calc output=<<output>> locale=<<locale>> notation=<<notation>> precision=<<precision>> show=<<show>> mode=<<mode>> calcPrec=<<calcPrec>> scope=<<scope>> silence=<<silence>>><<expr>></$calc>
</$list>