title: $:/plugins/nikorion/math/test
type: text/vnd.tiddlywiki

\define stateTidd() $:/state/plugins/nikorion/math/test

\function locale()   [<stateTidd>get[locale]else[en-US]]
\function notation() [<stateTidd>get[notation]else[auto]]
\function show()     [<stateTidd>get[show]else[result]]
\function mode()     [<stateTidd>get[mode]else[inline]]
\function silence()  [<stateTidd>get[silence]else[no]]
\function calcPrec() [<stateTidd>get[calcPrec]else[float]]
\function output()   [<stateTidd>get[output]else[katex]]

\procedure cleanValues()
<$action-setfield $tiddler=<<stateTidd>> $field="expression" $value="" />
<$action-setfield $tiddler=<<stateTidd>> $field="locale"     $value="en-US" />
<$action-setfield $tiddler=<<stateTidd>> $field="notation"   $value="auto" />
<$action-setfield $tiddler=<<stateTidd>> $field="show"       $value="result" />
<$action-setfield $tiddler=<<stateTidd>> $field="mode"       $value="inline" />
<$action-setfield $tiddler=<<stateTidd>> $field="silence"    $value="no" />
<$action-setfield $tiddler=<<stateTidd>> $field="calcPrec"   $value="float" />
<$action-setfield $tiddler=<<stateTidd>> $field="output"     $value="katex" />
\end cleanValues

