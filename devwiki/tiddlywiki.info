{
  "description": "TW-Math development wiki",
  "plugins": [
    "tiddlywiki/filesystem",
    "tiddlywiki/tiddlyweb",
    "tiddlywiki/katex",
    "tiddlywiki/highlight",
    "nikorion/math"
  ],
  "themes": [
    "tiddlywiki/vanilla"
  ],
  "pluginPath": "../plugins",
  "build": {
    "plugin-json": [
      "--output", "dist",
      "--savetiddler", "$:/plugins/nikorion/math", "TW-Math-Plugin.json", "application/json"
    ],
    "html": [
      "--output", "docs",
      "--rendertiddler", "$:/core/save/all", "TW-Math-Wiki.html", "text/plain"
    ]
  }
}
