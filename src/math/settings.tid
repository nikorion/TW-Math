title: $:/plugins/nikorion/math/settings
type: text/vnd.tiddlywiki
tags: $:/tags/ControlPanel/SettingsTab
caption: <<math-lingo Configs/Caption>>

\define stateTidd(attr) $:/state/plugins/nikorion/math/defaults/$attr$

\define resetBtn(attr)
<$set name="cfg" value=<<stateTidd $attr$>>>
<$button tooltip=<<math-lingo Configs/ResetTooltip>> class="tc-btn-invisible" disabled={{{ [<cfg>!is[tiddler]then[yes]else[no]] }}}>
<$action-deletetiddler $tiddler=<<cfg>>/>{{$:/core/images/refresh-button}}
</$button>
</$set>
\end

<style>
.math-cfg th, .math-cfg td { padding: 4px 10px; vertical-align: middle; border-left: 0; border-right: 0; }
.math-cfg td:first-child { font-family: monospace; font-weight: bold; width: 7em; }
.math-cfg td:last-child { text-align: center; }
.math-cfg .tc-radio { white-space: nowrap; margin-right: 4px; }
.math-cfg input { width: auto !important; }
</style>

<div class="math-cfg">

! <<math-lingo Configs/Title>>

<<math-lingo Configs/Description>>

<hr>

<table>
<tr><th><<math-lingo Configs/Attribute>></th><th><<math-lingo Configs/Value>></th><th></th></tr>

<tr>
<td>`output`</td>
<td>
<$tiddler tiddler=<<stateTidd output>>>
<$radio field="text" value="katex" default="katex">&nbsp;katex</$radio>
<$radio field="text" value="text">&nbsp;text</$radio>
</$tiddler>
</td>
<td><<resetBtn output>></td>
</tr>

<tr>
<td>`show`</td>
<td>
<$tiddler tiddler=<<stateTidd show>>>
<$radio field="text" value="result" default="result">&nbsp;result</$radio>
<$radio field="text" value="formula">&nbsp;formula</$radio>
<$radio field="text" value="full">&nbsp;full</$radio>
</$tiddler>
</td>
<td><<resetBtn show>></td>
</tr>

<tr>
<td>`mode`</td>
<td>
<$tiddler tiddler=<<stateTidd mode>>>
<$radio field="text" value="inline" default="inline">&nbsp;inline</$radio>
<$radio field="text" value="block">&nbsp;block</$radio>
</$tiddler>
</td>
<td><<resetBtn mode>></td>
</tr>

<tr>
<td>`decimal`</td>
<td>
<$tiddler tiddler=<<stateTidd decimal>>>
<$radio field="text" value="point" default="point">&nbsp;point</$radio>
<$radio field="text" value="comma">&nbsp;comma</$radio>
</$tiddler>
</td>
<td><<resetBtn decimal>></td>
</tr>

<tr>
<td>`notation`</td>
<td>
<$tiddler tiddler=<<stateTidd notation>>>
<$radio field="text" value="auto" default="auto">&nbsp;auto</$radio>
<$radio field="text" value="fixed">&nbsp;fixed</$radio>
<$radio field="text" value="scientific">&nbsp;scientific</$radio>
<$radio field="text" value="engineering">&nbsp;engineering</$radio>
<$radio field="text" value="bin">&nbsp;bin</$radio>
<$radio field="text" value="oct">&nbsp;oct</$radio>
<$radio field="text" value="hex">&nbsp;hex</$radio>
</$tiddler>
</td>
<td><<resetBtn notation>></td>
</tr>

<tr>
<td>`precision`</td>
<td>
<$let _lang={{{ [[$:/language]get[text]get[name]else[en-GB]] }}}>
<$edit-text tiddler=<<stateTidd precision>> field="text" placeholder={{{ [[$:/plugins/nikorion/math/language/]addsuffix<_lang>addsuffix[/Configs/PrecisionPlaceholder]get[text]else[6 (default)]] }}} tag="input" class="math-cfg-prec"/>
</$let>
</td>
<td><<resetBtn precision>></td>
</tr>

<tr>
<td>`calcPrec`</td>
<td>
<$tiddler tiddler=<<stateTidd calcPrec>>>
<$radio field="text" value="float" default="float">&nbsp;float</$radio>
<$radio field="text" value="64">&nbsp;64</$radio>
<$radio field="text" value="128">&nbsp;128</$radio>
<$radio field="text" value="256">&nbsp;256</$radio>
</$tiddler>
</td>
<td><<resetBtn calcPrec>></td>
</tr>

<tr>
<td>`silence`</td>
<td>
<$tiddler tiddler=<<stateTidd silence>>>
<$radio field="text" value="no" default="no">&nbsp;no</$radio>
<$radio field="text" value="yes">&nbsp;yes</$radio>
</$tiddler>
</td>
<td><<resetBtn silence>></td>
</tr>

</table>
</div>
